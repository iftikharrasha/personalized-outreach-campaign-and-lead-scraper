# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# .env is git-ignored; .env.example is committed.
# ─────────────────────────────────────────────────────────────

# Database — local PostgreSQL. Replace <password> with your `postgres` user password.
DATABASE_URL="postgresql://postgres:<password>@localhost:5432/lead_scraper"

# Web
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Scraper (used from Phase 2 onward)
SCRAPER_HEADLESS=true
SCROLL_DELAY_MIN_MS=3000
SCROLL_DELAY_MAX_MS=8000
MAX_RESULTS_PER_SEARCH=100
POLL_INTERVAL_MS=3000

# User-agent pool (JSON array of strings) — filled in during Phase 3
USER_AGENTS='[]'
